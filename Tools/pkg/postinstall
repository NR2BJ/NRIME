#!/bin/bash
# NRIME PKG postinstall script

INSTALL_DIR="/Library/Input Methods"
APP_PATH="$INSTALL_DIR/NRIME.app"
SETTINGS_PATH="$INSTALL_DIR/NRIMESettings.app"
# NRIMERestoreHelper removed — NRIME handles input source recovery internally
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Versions/Current/Frameworks/LaunchServices.framework/Versions/Current/Support/lsregister"

# Kill existing processes
killall NRIME 2>/dev/null || true
killall NRIMESettings 2>/dev/null || true
killall NRIMERestoreHelper 2>/dev/null || true
killall mozc_server 2>/dev/null || true
sleep 1

# Clean stale mozc lock files (read-only, chmod first)
CONSOLE_USER="$(stat -f "%Su" /dev/console 2>/dev/null || true)"
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    MOZC_DIR="$(eval echo "~$CONSOLE_USER")/Library/Application Support/Mozc"
    mkdir -p "$MOZC_DIR"
    chown "$CONSOLE_USER":staff "$MOZC_DIR" 2>/dev/null || true
    chmod 644 "$MOZC_DIR/.server.lock" 2>/dev/null || true
    rm -f "$MOZC_DIR/.server.lock" "$MOZC_DIR/.session.ipc" 2>/dev/null || true
fi

# Remove quarantine
xattr -cr "$APP_PATH" 2>/dev/null || true
xattr -cr "$SETTINGS_PATH" 2>/dev/null || true

# Register with LaunchServices
"$LSREGISTER" "$APP_PATH" 2>/dev/null || true
"$LSREGISTER" "$SETTINGS_PATH" 2>/dev/null || true

# Re-enable input sources using pre-compiled tool (avoids swift-frontend notification)
SCRIPT_DIR="$(dirname "$0")"
"$SCRIPT_DIR/enable_input_source" 2>/dev/null || true

# Clean up old loginrestore LaunchAgent (from previous versions — no longer needed)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    CONSOLE_UID="$(id -u "$CONSOLE_USER" 2>/dev/null || true)"
    if [ -n "$CONSOLE_UID" ]; then
        launchctl bootout "gui/$CONSOLE_UID" "/Library/LaunchAgents/com.nrime.inputmethod.loginrestore.plist" 2>/dev/null || true
        launchctl bootout "gui/$CONSOLE_UID" "$(eval echo "~$CONSOLE_USER")/Library/LaunchAgents/com.nrime.inputmethod.loginrestore.plist" 2>/dev/null || true
    fi
    rm -f "/Library/LaunchAgents/com.nrime.inputmethod.loginrestore.plist" 2>/dev/null || true
    rm -f "$(eval echo "~$CONSOLE_USER")/Library/LaunchAgents/com.nrime.inputmethod.loginrestore.plist" 2>/dev/null || true
fi

# Clean up old mozc LaunchAgent if present (from previous versions)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    CONSOLE_UID="$(id -u "$CONSOLE_USER" 2>/dev/null || true)"
    if [ -n "$CONSOLE_UID" ]; then
        launchctl bootout "gui/$CONSOLE_UID" "/Library/LaunchAgents/com.nrime.inputmethod.mozcserver.plist" 2>/dev/null || true
    fi
    rm -f "/Library/LaunchAgents/com.nrime.inputmethod.mozcserver.plist" 2>/dev/null || true
    rm -f "$(eval echo "~$CONSOLE_USER")/Library/LaunchAgents/com.nrime.inputmethod.mozcserver.plist" 2>/dev/null || true
fi

exit 0
