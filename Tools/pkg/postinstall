#!/bin/bash
# NRIME PKG postinstall script
# Runs after PKG installs files to /Library/Input Methods/

INSTALL_DIR="/Library/Input Methods"
APP_PATH="$INSTALL_DIR/NRIME.app"
SETTINGS_PATH="$INSTALL_DIR/NRIMESettings.app"
LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Versions/Current/Frameworks/LaunchServices.framework/Versions/Current/Support/lsregister"
PLISTBUDDY="/usr/libexec/PlistBuddy"

# 1. Kill existing processes
killall NRIME 2>/dev/null || true
killall NRIMESettings 2>/dev/null || true
killall mozc_server 2>/dev/null || true
sleep 1

# 2. Remove quarantine attributes (critical for unsigned apps)
xattr -cr "$APP_PATH" 2>/dev/null || true
xattr -cr "$SETTINGS_PATH" 2>/dev/null || true

# 3. Set executable permissions
chmod +x "$APP_PATH/Contents/MacOS/NRIME" 2>/dev/null || true
chmod +x "$APP_PATH/Contents/Resources/mozc_server" 2>/dev/null || true
chmod +x "$SETTINGS_PATH/Contents/MacOS/NRIMESettings" 2>/dev/null || true

# 4. Register with LaunchServices
"$LSREGISTER" "$APP_PATH" 2>/dev/null || true
"$LSREGISTER" "$SETTINGS_PATH" 2>/dev/null || true

# 5. Get console user for per-user input source registration
CONSOLE_USER=$(/usr/bin/stat -f%Su /dev/console 2>/dev/null)
if [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ]; then
    CONSOLE_USER=$(/usr/bin/who 2>/dev/null | grep console | head -1 | awk '{print $1}')
fi

# 6. Register NRIME in AppleEnabledInputSources (works without swift)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    USER_HOME=$(/usr/bin/dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
    USER_PLIST="$USER_HOME/Library/Preferences/com.apple.HIToolbox.plist"

    if [ -f "$USER_PLIST" ]; then
        # Check if NRIME.en is already registered
        FOUND=false
        INDEX=0
        while true; do
            BID=$("$PLISTBUDDY" -c "Print :AppleEnabledInputSources:${INDEX}:Bundle\ ID" "$USER_PLIST" 2>/dev/null)
            [ $? -ne 0 ] && break
            MODE=$("$PLISTBUDDY" -c "Print :AppleEnabledInputSources:${INDEX}:Input\ Mode" "$USER_PLIST" 2>/dev/null)
            if [ "$BID" = "com.nrime.inputmethod.app" ] && [ "$MODE" = "com.nrime.inputmethod.app.en" ]; then
                FOUND=true
                break
            fi
            INDEX=$((INDEX + 1))
        done

        # Add NRIME.en entry if not found
        if [ "$FOUND" = false ]; then
            "$PLISTBUDDY" -c "Add :AppleEnabledInputSources:${INDEX} dict" "$USER_PLIST" 2>/dev/null || true
            "$PLISTBUDDY" -c "Add :AppleEnabledInputSources:${INDEX}:Bundle\ ID string com.nrime.inputmethod.app" "$USER_PLIST" 2>/dev/null || true
            "$PLISTBUDDY" -c "Add :AppleEnabledInputSources:${INDEX}:Input\ Mode string com.nrime.inputmethod.app.en" "$USER_PLIST" 2>/dev/null || true
            "$PLISTBUDDY" -c "Add :AppleEnabledInputSources:${INDEX}:InputSourceKind string Input\ Mode" "$USER_PLIST" 2>/dev/null || true
        fi
    fi
fi

# 7. Enable and select via TIS API (only if swift is available)
if command -v swift >/dev/null 2>&1; then
    swift -e '
import Carbon
import Foundation

let bundleId = "com.nrime.inputmethod.app"
let conditions = [kTISPropertyBundleID: bundleId] as CFDictionary
guard let sources = TISCreateInputSourceList(conditions, true)?.takeRetainedValue() as? [TISInputSource] else { exit(0) }

for source in sources {
    TISEnableInputSource(source)
}

let selectConditions = [
    kTISPropertyBundleID: bundleId,
    kTISPropertyInputSourceID: "com.nrime.inputmethod.app.en"
] as CFDictionary
if let selectSources = TISCreateInputSourceList(selectConditions, false)?.takeRetainedValue() as? [TISInputSource],
   let nrime = selectSources.first {
    TISSelectInputSource(nrime)
}
' 2>/dev/null || true
fi

exit 0
